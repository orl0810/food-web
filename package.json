{
  "name": "food-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "start:api": "tsx local-api/server.ts",
    "dev": "concurrently -n api,web -c blue,green \"npm run start:api\" \"npm run start\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:food-web": "node dist/food-web/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/platform-browser": "^21.2.16",
    "@angular/platform-browser-dynamic": "^21.2.16",
    "@angular/platform-server": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@angular/ssr": "^21.2.14",
    "@supabase/supabase-js": "^2.107.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jasmine": "~5.1",
    "@types/node": "^22.19.19",
    "jasmine-core": "~5.6",
    "karma": "~6.4",
    "karma-chrome-launcher": "~3.2",
    "karma-coverage": "~2.2",
    "karma-jasmine": "~5.1",
    "karma-jasmine-html-reporter": "~2.1",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.15",
    "tsx": "^4.20.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3"
